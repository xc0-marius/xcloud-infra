# =========================
# xCloud infra environment
# Copy this file to .env and replace all values before starting the stack.
# =========================

PUBLIC_IP=46.225.19.105
BASE_DOMAIN=xcloud.gg
TZ=Europe/Oslo

# Shared PostgreSQL password for Authentik's database user.
PG_PASS=change_me_long_random_postgres_password

# Generate with:
# openssl rand -base64 48
AUTHENTIK_SECRET_KEY=change_me_long_random_authentik_secret

# deSEC DNS API token used by Traefik ACME DNS-01 challenge.
DESEC_TOKEN=change_me_desec_token

# pgAdmin initial login.
PGADMIN_DEFAULT_EMAIL=admin@xcloud.gg
PGADMIN_DEFAULT_PASSWORD=change_me_long_random_pgadmin_password
